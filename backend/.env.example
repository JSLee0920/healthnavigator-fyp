DATABASE_URL=postgresql+asyncpg://postgres:your-postgres-password@localhost:5433/healthnav
QDRANT_URL=http://localhost:6333

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Groq API key for Llama Models
GROQ_API_KEY=gsk_your_groq_api_key
# Secret used to sign JWTs (generate: openssl rand -hex 32)
SECRET_KEY=your-secret-key
# Hugging Face token for downloading models
HF_TOKEN=hf_your_huggingface_token
# Shared secret required by POST /auth/register-admin
ADMIN_CREATION_SECRET=your-admin-creation-secret

# Comma-separated list of allowed frontend origins for CORS.
# Add your Vercel URL(s) here, e.g. https://your-app.vercel.app
FRONTEND_ORIGINS=http://localhost:3000

# Cookie attributes. For ngrok+Vercel (cross-site) set: none / true
# For pure localhost dev keep: lax / false
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
